{
  "name": "neurapath-homepage",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "license": "MIT",
  "packageManager": "bun@1.3.13",
  "description": "Neurapath homepage - Beautiful and powerful learning platform built with SvelteKit and deployed on Cloudflare Workers",
  "main": "svelte.config.js",
  "keywords": [
    "learning",
    "education",
    "flashcards",
    "spaced-repetition",
    "sveltekit",
    "cloudflare"
  ],
  "author": "Martin Jakobsson <Hello@neurapath.shop>",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "cf-typegen": "wrangler types ./src/worker-configuration.d.ts",
    "deploy": "bun run build && bun run cf-typegen && wrangler deploy",
    "clean": "rm -rf .svelte-kit && rm -rf node_modules && rm -rf .wrangler && rm -rf .svelte-kit && rm -f bun.lock && rm -f package-lock.json && bun i"
  },
  "devDependencies": {
    "@lucide/svelte": "^1.14.0",
    "@sveltejs/adapter-cloudflare": "^7.2.8",
    "@sveltejs/kit": "^2.58.0",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.4",
    "clsx": "^2.1.1",
    "svelte": "^5.55.5",
    "svelte-check": "^4.4.7",
    "tailwind-merge": "^3.5.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.2.4",
    "tslib": "^2.8.1",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "wrangler": "^4.87.0"
  },
  "dependencies": {
    "posthog-js": "^1.372.5",
    "posthog-node": "^5.32.0"
  }
}
